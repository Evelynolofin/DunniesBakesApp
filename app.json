{
  "expo": {
    "name": "Dunnies Bakes",
    "slug": "Dunnies-Bakes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dunnies-logo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/dunnies-logo.png",
        "backgroundImage": "./assets/images/dunnies-logo.png",
        "monochromeImage": "./assets/images/dunnies-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.evelynolofin.DunniesBakes"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/dunnies-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dunnies-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86920ab4-399e-4ca3-afff-c2a539050c1c"
      }
    }
  }
}
