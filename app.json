{
  "expo": {
    "name": "Dunnies Kitchen",
    "slug": "Dunnies-Kitchen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dunnies-logo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/dunnies-logo.png",
        "backgroundImage": "./assets/images/dunnies-logo.png",
        "monochromeImage": "./assets/images/dunnies-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.evelynolofin.DunniesKitchen",
      "navigationBarColor": "#00000000"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/dunnies-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dunnies-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-navigation-bar",
        {
          "visible": "immersive",
          "backgroundColor": "#00000000",
          "barStyle": "dark"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "visible": "immersive",
        "backgroundColor": "#00000000",
        "barStyle": "dark"
      },
      "eas": {
        "projectId": "002fdf9f-2a61-4d80-96f2-8e3fce7d546c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/002fdf9f-2a61-4d80-96f2-8e3fce7d546c"
    },
    "owner": "evelynolofin"
  }
}
